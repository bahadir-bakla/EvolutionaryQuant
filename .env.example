# EvolutionaryQuant — Environment Variables Template
# Kopyala: cp .env.example .env  →  kendi key'lerini doldur

# ─── MiroFish Service ─────────────────────────────────────────────────────────
# MiroFish'in çalıştığı URL (VPS'te lokal Docker ise localhost kalır)
MIROFISH_URL=http://localhost:5001

# ─── MiroFish LLM Keys (mirofish/.env dosyasına da kopyala) ──────────────────
# Groq (ücretsiz, hızlı): https://console.groq.com → API Keys → Create
LLM_API_KEY=gsk_YOUR_GROQ_KEY_HERE
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# xAI (alternatif LLM): https://console.x.ai → API Keys
XAI_API_KEY=xai-YOUR_XAI_KEY_HERE

# Zep Cloud (agent memory): https://app.getzep.com → Settings → API Keys
ZEP_API_KEY=z_YOUR_ZEP_KEY_HERE

# ─── News Feed (isteğe bağlı — RSS ücretsiz çalışır) ─────────────────────────
# NewsAPI: https://newsapi.org → Register → API Key (ücretsiz: 100 req/gün)
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage (haber sentiment): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
